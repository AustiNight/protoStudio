{
  "name": "prontoproto-studio",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "deploy:pages": "npm run build && CI=1 NO_COLOR=1 npx wrangler@4.71.0 pages deploy dist --project-name prontoproto-studio --branch main --commit-dirty=true",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:imagery": "vitest run tests/unit/engine/public-domain.test.ts tests/unit/engine/imagery-placeholders.test.ts tests/unit/engine/preview-image-assets.test.ts tests/integration/builder-loop-imagery.test.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest watch tests/unit/",
    "typecheck": "tsc --noEmit",
    "pricing:check": "node scripts/pricing-calibration-check.js --max-stale-days 45 --verify-sources --check-catalog"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^5.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.4",
    "vitest": "^1.6.0"
  }
}
