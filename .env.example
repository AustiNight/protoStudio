# =========================
# Runtime mode and logging
# =========================

# true = use real provider calls in local dev
# false = keep mock LLM flow in dev (fast deterministic previews)
VITE_USE_REAL_LLM=false

# true = print info/debug logs to browser console and include deeper traces
VITE_DEBUG_LOGS=true

# true = show the Log Viewer panel in the UI
VITE_LOG_VIEWER_ENABLED=true

# Max in-memory log entries retained in the Log Viewer
VITE_LOG_VIEWER_MAX_ENTRIES=500

# =========================
# UI timing controls
# =========================

# Delay before auto-running the next builder cycle (ms)
VITE_BUILDER_LOOP_DELAY_MS=220

# Preview swap animation duration (ms)
VITE_PREVIEW_SWAP_DURATION_MS=700

# Validation state duration before preview marked "passed" (ms)
VITE_PREVIEW_VALIDATION_DURATION_MS=1200

# Iframe sandbox flags for preview interactivity.
# Recommended: allow-scripts allow-forms allow-same-origin
VITE_PREVIEW_IFRAME_SANDBOX=allow-scripts allow-forms allow-same-origin

# OpenAI request transport mode:
# - direct: browser calls OpenAI with user-provided key
# - proxy: browser calls your Cloudflare endpoint at VITE_OPENAI_PROXY_BASE_URL
# If proxy is on a different origin than the app, set
# OPENAI_PROXY_ALLOWED_ORIGINS (Cloudflare Pages/Workers env var) to a comma-separated
# allowlist, e.g. "https://prontoproto.studio,https://www.prontoproto.studio".
# Default behavior in code: proxy for all environments.
VITE_OPENAI_REQUEST_MODE=proxy
VITE_OPENAI_PROXY_BASE_URL=/api/openai

# =========================
# Default model selections
# =========================

# Allowed providers: openai | anthropic | google
VITE_DEFAULT_CHAT_PROVIDER=openai
VITE_DEFAULT_CHAT_MODEL=gpt-4o-mini
VITE_DEFAULT_BUILDER_PROVIDER=openai
VITE_DEFAULT_BUILDER_MODEL=gpt-4o-mini

# OpenAI thinking level defaults for each role.
# Allowed: default | none | minimal | low | medium | high | xhigh
# App behavior:
# - For models that support reasoning, this value is applied.
# - For models that do not support reasoning, the setting is ignored.
# - If xhigh is not supported by a selected model, the app safely falls back.
VITE_OPENAI_CHAT_THINKING_LEVEL=xhigh
VITE_OPENAI_BUILDER_THINKING_LEVEL=xhigh

# =========================
# Optional local secrets
# =========================
# These prefill local settings on fresh load before encrypted settings are saved.
# Leave blank if you do not want secrets in env files.
#
# OpenAI is server-managed by default:
# - Local dev proxy reads OPENAI_API_KEY from process env (not VITE_*)
# - Production proxy reads OPENAI_API_KEY from Cloudflare Pages secrets
# VITE_OPENAI_API_KEY is only for temporary direct-mode diagnostics.
OPENAI_API_KEY=
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GOOGLE_API_KEY=

VITE_GITHUB_TOKEN=
VITE_CLOUDFLARE_TOKEN=
VITE_NETLIFY_TOKEN=
VITE_VERCEL_TOKEN=
